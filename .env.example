# Copy to .env and fill in. Only the providers you actually use are needed.

# LLM (one of these is enough; the provider is selected by configuration)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Speech to text
DEEPGRAM_API_KEY=

# Text to speech (Piper needs no key)
CARTESIA_API_KEY=

# Telegram channel (token from @BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: LLM observability (Opik). Leave empty to disable entirely.
# Cloud: comet.com account. Self-host: set OPIK_URL_OVERRIDE instead.
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=polyglot-booking-agent

# Realtime browser calls, self-hosted (tools/livekit-server --dev)
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Perspective: PSTN telephony (Twilio SIP trunk). Empty = channel off.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
