# Copy to .env and fill in. Only the providers you actually use are needed.

# LLM (one of these is enough; the provider is selected by configuration)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Speech to text
DEEPGRAM_API_KEY=

# Text to speech (Piper needs no key)
CARTESIA_API_KEY=

# Telegram channel (token from @BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: LLM observability (Opik). Leave empty to disable entirely.
# Cloud: comet.com account. Self-host: set OPIK_URL_OVERRIDE instead.
OPIK_API_KEY=
OPIK_WORKSPACE=
OPIK_PROJECT_NAME=polyglot-booking-agent
